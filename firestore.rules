rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Block all access to secrets collection (Cloud Functions Admin SDK bypasses this anyway)
    match /_secrets/{document=**} {
      allow read, write: if false;
    }
    // Default deny. Grant collection-specific access only after Firebase Auth
    // and ownership rules are defined for production data.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
